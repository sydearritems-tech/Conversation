                seg.TextXAlignment = Enum.TextXAlignment.Left
                seg.TextYAlignment = Enum.TextYAlignment.Top
                seg.LineHeight = 1.35
                seg.Text = table.concat(buf, "\n")
                seg.LayoutOrder = order
                seg.Parent = holder
                order = order + 1
                buf = {}
                bufLen = 0
            end
            for _, line in ipairs(lines) do
                table.insert(buf, line)
                bufLen = bufLen + #line + 1
                if bufLen >= 3500 then
                    flush()
                end
            end
            flush()
        end

        local function countLines(text)
            local n = 1
            for _ in text:gmatch("\n") do n = n + 1 end
            return n
        end

        local lineCount = countLines(cleanCode)
        local bigCode = lineCount > 1000

        if isStreamed then
            local charCount = #cleanCode
            codeLabel.Text = ""
            codeLabel.RichText = not bigCode
            task.wait()
            updateCanvasAndScroll(true)
            local step = 10
            for i = 1, charCount, step do
                local shown = cleanCode:sub(1, math.min(i + step - 1, charCount))
                if bigCode then
                    codeLabel.Text = shown
                else
                    codeLabel.Text = highlightLua(shown)
                end
                updateCanvasAndScroll(true)
                task.wait(0.004)
            end
            if bigCode then
                codeLabel.Text = ""
                codeLabel.Visible = false
                renderBigCode(cleanCode)
            else
                codeLabel.Text = highlightLua(cleanCode)
            end
            updateCanvasAndScroll(true)
            createFooter()
            task.wait()
            updateCanvasAndScroll(true)
        else
            if bigCode then
                renderBigCode(cleanCode)
            else
                codeLabel.Text = highlightLua(cleanCode)
            end
            createFooter()
            updateCanvasAndScroll()
        end

        return codeWrapper
    end

