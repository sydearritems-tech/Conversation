    local function stripCommentsFromCode(code)
        local outLines = {}
        for line in (code .. "\n"):gmatch("(.-)\n") do
            if line:match("%-%-%[%[") or line:match("%]%]") then
                table.insert(outLines, line)
            elseif line:match("^%s*%-%-") then
            else
                local cleaned = line:gsub("(%s+)%-%-[^\n]*$", "")
                if cleaned:match("%S") or not line:match("%-%-") then
                    table.insert(outLines, cleaned)
                end
            end
        end
        return table.concat(outLines, "\n")
    end

    local function stripCodeComments(text)
        local result = {}
        local pos = 1
        local inCode = false
        while pos <= #text do
            local s = text:find("```", pos, true)
            if not s then
                local chunk = text:sub(pos)
                table.insert(result, inCode and stripCommentsFromCode(chunk) or chunk)
                break
            end
            local before = text:sub(pos, s - 1)
            table.insert(result, inCode and stripCommentsFromCode(before) or before)
            table.insert(result, "```")
            inCode = not inCode
            pos = s + 3
        end
        return table.concat(result)
    end

