    local function findPlayerByText(text)
        local Players = game:GetService("Players")
        text = (text or ""):lower()
        for _, p in ipairs(Players:GetPlayers()) do
            local n, d = p.Name:lower(), p.DisplayName:lower()
            if (" " .. text .. " "):find(" " .. n .. " ", 1, true) or (" " .. text .. " "):find(" " .. d .. " ", 1, true) then
                return p
            end
        end
        for _, p in ipairs(Players:GetPlayers()) do
            local n, d = p.Name:lower(), p.DisplayName:lower()
            if text:find(n, 1, true) or text:find(d, 1, true) then
                return p
            end
        end
        return nil
    end

    local function getTargetPlayer(query)
        local Players = game:GetService("Players")
        if not query then return nil end
        query = query:gsub("^%s+", ""):gsub("%s+$", ""):lower()
        if query == "" then return nil end
        if SELF_WORDS[query] then return Players.LocalPlayer end
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == query or p.DisplayName:lower() == query then
                return p
            end
        end
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(query, 1, true) or p.DisplayName:lower():find(query, 1, true) then
                return p
            end
        end
        return nil
    end

    local function resolveTarget(userMessage)
        local Players = game:GetService("Players")
        local lower = userMessage:lower()
        local quoted = userMessage:match("[\"']([^\"']+)[\"']")
        if quoted then
            local p = getTargetPlayer(quoted)
            if p then return p, p.Name end
            return nil, quoted
        end
        local matched = findPlayerByText(lower)
        if matched then return matched, matched.Name end
        local explicit = userMessage:match("[Pp]layer%s+([%w_]+)") or userMessage:match("[Uu]ser%s+([%w_]+)")
            or userMessage:match("[Kk]ullanıcı%s+([%w_]+)") or userMessage:match("[Oo]yuncu%s+([%w_]+)")
            or userMessage:match("[Kk]i[sş]i%s+([%w_]+)")
        if explicit then
            explicit = explicit:gsub("[%.,!%?]+$", "")
            local p = getTargetPlayer(explicit)
            if p then return p, p.Name end
            return nil, explicit
        end
        return nil, nil
    end

    local function extractName(userMessage)
        local _, name = resolveTarget(userMessage)
        return name
    end

