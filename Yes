    local lastText = ""
    local function onTextChanged()
        local text = inputBox.Text
        if isSending then
            lastText = text
            return
        end
        if #text > #lastText then
            local addedChar = text:sub(#lastText + 1, #lastText + 1)
            if addedChar == "\n" then
                local shiftHeld = user_input_service:IsKeyDown(Enum.KeyCode.LeftShift)
                    or user_input_service:IsKeyDown(Enum.KeyCode.RightShift)
                if not shiftHeld then
                    inputBox.Text = lastText
                    lastText = inputBox.Text
                    local message = inputBox.Text:match("^%s*(.-)%s*$")
                    if message ~= "" then
                        inputBox.Text = ""
                        lastText = ""
                        task.wait()
                        updateInputHeight()
                        sendAIMessage(message)
                    end
                    return
                end
            end
        end
        lastText = text
        updateInputHeight()
    end

