                plainText = plainText:gsub("\n(%d+%.%s)", "\n\n\n%1")
                local charCount = #plainText
                local i = 1
                while i <= charCount do
                    local j = math.min(i + 9, charCount)
                    while j < charCount and plainText:byte(j + 1) and plainText:byte(j + 1) >= 128 and plainText:byte(j + 1) < 192 do
                        j = j + 1
                    end
                    label.Text = plainText:sub(1, j)
                    updateCanvasAndScroll(true)
                    task.wait(0.004)
                    i = j + 1
                end
                label.RichText = true
                label.Text = convertToRichText(plainText)
