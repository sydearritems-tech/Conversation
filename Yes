    local function resolveUserId(name)
        local Players = game:GetService("Players")
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == name:lower() or p.DisplayName:lower() == name:lower() then
                return p.UserId, p.Name
            end
        end
        local ok, uid = pcall(function()
            return Players:GetUserIdFromNameAsync(name)
        end)
        if ok and uid then return uid, name end
        local data = postJson("https://users.roblox.com/v1/usernames/users", {usernames = {name}, excludeBannedUsers = false})
        if data and data.data and data.data[1] and data.data[1].id then
            return data.data[1].id, data.data[1].name or name
        end
        return nil, name
    end

