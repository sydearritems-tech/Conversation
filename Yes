    local function moveLocalTo(targetPlayer, mode)
        local Players = game:GetService("Players")
        local RunService = game:GetService("RunService")
        local me = Players.LocalPlayer
        return pcall(function()
            local myChar = me.Character or me.CharacterAdded:Wait()
            local myRoot = myChar:WaitForChild("HumanoidRootPart")
            local myHum = myChar:FindFirstChildOfClass("Humanoid")
            local tChar = targetPlayer.Character or targetPlayer.CharacterAdded:Wait()
            local tRoot = tChar:WaitForChild("HumanoidRootPart")

            local function offset()
                local r = getCharRoot(targetPlayer)
                if not r then return nil end
                return r.CFrame * CFrame.new(0, 0, 4)
            end

            if mode == "walk" then
                if myHum then
                    myHum:MoveTo(tRoot.Position)
                    local arrived = false
                    local c1
                    c1 = myHum.MoveToFinished:Connect(function() arrived = true end)
                    local t0 = tick()
                    while not arrived and tick() - t0 < 8 do
                        local r = getCharRoot(targetPlayer)
                        if r then myHum:MoveTo(r.Position) end
                        task.wait(0.25)
                    end
                    if c1 then c1:Disconnect() end
                else
                    local g = offset()
                    if g then myRoot.CFrame = g end
                end
            elseif mode == "tween" then
                local TweenService = game:GetService("TweenService")
                local g = offset()
                if not g then return end
                local dist = (myRoot.Position - tRoot.Position).Magnitude
                local dur = math.clamp(dist / 60, 0.4, 6)
                local tw = TweenService:Create(myRoot, TweenInfo.new(dur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = g})
                tw:Play()
                tw.Completed:Wait()
                local g2 = offset()
                if g2 then myRoot.CFrame = g2 end
            else
                local elapsed = 0
                local conn
                conn = RunService.Heartbeat:Connect(function(dt)
                    elapsed = elapsed + dt
                    local c = me.Character
                    local r = c and c:FindFirstChild("HumanoidRootPart")
                    local g = offset()
                    if r and g then
                        local h = c:FindFirstChildOfClass("Humanoid")
                        if h then h.Sit = false end
                        r.CFrame = g
                    end
                    if elapsed > 1.2 then conn:Disconnect() end
                end)
                task.wait(1.25)
            end
        end)
    end

