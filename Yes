    function callDeepSeekFull(model, extraInstruction, forceEnglish)
        local reply, err, finishReason = callDeepSeekAPI(model, extraInstruction, forceEnglish)
        if err or not reply then return reply, err end
        local fullReply = reply
        local tries = 0
        while finishReason == "length" and tries < 12 do
            tries = tries + 1
            table.insert(conversationHistory, {role = "assistant", content = fullReply})
            local contInstr = (extraInstruction or "") .. " Your previous message was cut off because it hit the length limit. Continue the response from EXACTLY where it stopped, do not repeat anything you already wrote, do not add any greeting or intro, just continue the remaining text or code seamlessly."
            local part, perr, freason = callDeepSeekAPI(model, contInstr, forceEnglish)
            table.remove(conversationHistory)
            if perr or not part or part == "" then break end
            fullReply = fullReply .. part
            finishReason = freason
        end
        return fullReply, nil
    end

