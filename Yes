        local namesScript = lower:find("infinite yield") or lower:find("infiniteyield") or lower:find("scan remotes") or lower:find("remote scanner") or lower:find("ac6") or lower:find("tool giver") or lower:find("toolgiver") or lower:find("chat logger") or lower:find("chatlogger") or (lower:find("fly") and (lower:find("script") or lower:find("kod")))
        if not (wantsScript and namesScript) then return nil end
        if lower:find("infinite yield") or lower:find("infiniteyield") or (lower:find("iy") and lower:find("admin")) then
            return INFINITE_YIELD_CODE, "Infinite Yield Admin"
        elseif lower:find("scan remotes") or lower:find("remote scanner") or (lower:find("remote") and (lower:find("scan") or lower:find("list") or lower:find("tara"))) then
            return SCAN_REMOTES_CODE, "Remote Scanner"
        elseif lower:find("ac6") then
            return AC6_SCRIPT_CODE, "AC6 Sound"
        elseif lower:find("tool giver") or lower:find("toolgiver") or (lower:find("tool") and lower:find("give")) then
            return TOOL_GIVER_CODE, "Tool Giver"
        elseif lower:find("chat logger") or lower:find("chatlogger") or (lower:find("chat") and lower:find("log")) then
            return CHAT_LOGGER_CODE, "Chat Logger"
        elseif lower:find("fly") then
            return FLY_SCRIPT_CODE, "Fly"
        end
        return nil
    end

    function sendAIMessage(userMessage, extraInstruction, forceEnglish)
        local currentTime = os.time()
        if welcomeOverlay then animateHideWelcome() end
        if suggestionButtonsFrame then animateHideSuggestionButtons() end
        lastMessageTime = currentTime
        isSending = true
        if minimizedAdviceButton and not (suggestionButtonsFrame and suggestionButtonsFrame.Parent == container) then
            minimizedAdviceButton.Visible = true
        end
        addAIMessage("user", userMessage)
        table.insert(conversationHistory, {role = "user", content = userMessage})

        local lower = userMessage:lower()
        if lower:find("dark") and (lower:find("ai") or lower:find("mode") or lower:find("switch")) then
            isSending = false
            switchToDarkAI()
            return
        elseif lower:find("menu") or lower:find("back") or lower:find("return") or (lower:find("ana") and lower:find("menü")) or (lower:find("show") and lower:find("buttons")) then
            if isDarkMode then
                isSending = false
                showDarkButtons()
                addAIMessage("ai", "Dark AI menu restored.")
            else
                isSending = false
                showNormalButtons()
                addAIMessage("ai", "Normal mode menu restored.")
            end
            return
        end

        if not extraInstruction then
            local typingFrame, dotAnim = spawnTypingBubble()
            task.spawn(function()
                local intent = "CHAT"
                local trimmed = lower:gsub("^%s+", ""):gsub("%s+$", "")
                local greetings = {hi=true, hey=true, hello=true, merhaba=true, selam=true, sa=true, ["s.a"]=true, ["nasılsın"]=true, ["how are you"]=true, yo=true}
                if not greetings[trimmed] and #trimmed > 2 then
                    local okC, c = pcall(function() return classifyMessage(userMessage) end)
                    if okC and c then intent = c end
                end
                if intent == "ACTION" then
                    runAICodeQuery(userMessage, typingFrame, dotAnim)
                    return
                end
                local actualModel = modelMap[currentAIModel] or "deepseek-chat"
                local response, err = callDeepSeekFull(actualModel, nil, false)
                dotAnim:Disconnect()
                typingFrame:Destroy()
                isSending = false
                if err then
                    addAIMessage("ai", "Error: " .. err)
                elseif response then
                    table.insert(conversationHistory, {role = "assistant", content = response})
                    addAIMessageStreamed("ai", response)
                end
            end)
            return
        end

        local typingFrame, dotAnim = spawnTypingBubble()
        task.spawn(function()
            local actualModel = modelMap[currentAIModel] or "deepseek-chat"
            local response, err = callDeepSeekFull(actualModel, extraInstruction, forceEnglish)
            dotAnim:Disconnect()
            typingFrame:Destroy()
            isSending = false
            if err then
                addAIMessage("ai", "Error: " .. err)
            elseif response then
                table.insert(conversationHistory, {role = "assistant", content = response})
                addAIMessageStreamed("ai", response)
            end
        end)
    end

