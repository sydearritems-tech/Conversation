    local function escapeRich(s)
        return (s:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;"))
    end

    local function highlightLuaPlain(code)
        local out = {}
        local i = 1
        local n = #code
        local KW = "rgb(197, 134, 192)"
        local GLOB = "rgb(86, 156, 214)"
        local STR = "rgb(206, 145, 120)"
        local NUM = "rgb(181, 206, 168)"
        local COM = "rgb(106, 153, 85)"
        local FUNC = "rgb(220, 220, 170)"
        local function push(color, text)
            out[#out + 1] = "<font color=\"" .. color .. "\">" .. escapeRich(text) .. "</font>"
        end
        local function pushPlain(text)
            out[#out + 1] = escapeRich(text)
        end
        while i <= n do
            local c = code:sub(i, i)
            local two = code:sub(i, i + 1)
            if two == "--" then
                local rest
                if code:sub(i, i + 3) == "--[[" then
                    local e = code:find("]]", i + 4, true)
                    rest = e and code:sub(i, e + 1) or code:sub(i)
                else
                    local e = code:find("\n", i, true)
                    rest = e and code:sub(i, e - 1) or code:sub(i)
                end
                push(COM, rest)
                i = i + #rest
            elseif c == "\"" or c == "'" then
                local j = i + 1
                while j <= n do
                    local cc = code:sub(j, j)
                    if cc == "\\" then j = j + 2
                    elseif cc == c then j = j + 1 break
                    else j = j + 1 end
                end
                local str = code:sub(i, j - 1)
                push(STR, str)
                i = j
            elseif code:sub(i, i + 1) == "[[" then
                local e = code:find("]]", i + 2, true)
                local str = e and code:sub(i, e + 1) or code:sub(i)
                push(STR, str)
                i = i + #str
            elseif c:match("%d") then
                local num = code:match("^[%dxXa-fA-F%.]+", i) or c
                push(NUM, num)
                i = i + #num
            elseif c:match("[%a_]") then
                local word = code:match("^[%w_]+", i)
                local afterIdx = i + #word
                local afterChar = code:sub(afterIdx, afterIdx):match("%S") and code:sub(afterIdx):match("^%s*(.)") or ""
                if LUA_KEYWORDS[word] then
                    push(KW, word)
                elseif LUA_GLOBALS[word] then
                    push(GLOB, word)
                elseif afterChar == "(" then
                    push(FUNC, word)
                else
                    pushPlain(word)
                end
                i = afterIdx
            else
                pushPlain(c)
                i = i + 1
            end
        end
        return table.concat(out)
    end

    local function highlightLua(code)
        local hasDiff = code:find("\n%+ ") or code:find("\n%- ") or code:match("^%+ ") or code:match("^%- ")
        if not hasDiff then
            return highlightLuaPlain(code)
        end
        local ADD = "rgb(106, 220, 120)"
        local DEL = "rgb(240, 110, 110)"
        local lines = {}
        for line in (code .. "\n"):gmatch("(.-)\n") do
            local marker = line:sub(1, 2)
            if marker == "+ " then
                lines[#lines + 1] = "<font color=\"" .. ADD .. "\">" .. escapeRich(line) .. "</font>"
            elseif marker == "- " then
                lines[#lines + 1] = "<font color=\"" .. DEL .. "\">" .. escapeRich(line) .. "</font>"
            else
                lines[#lines + 1] = highlightLuaPlain(line)
            end
        end
        return table.concat(lines, "\n")
    end

    local function extractLanguage(rawCode)
        local firstLine = rawCode:match("^([^\n]*)\n?")
        if firstLine then
            local lang = firstLine:match("^%s*(%a+)%s*$")
            if lang and #lang > 0 and #lang <= 20 then
                return lang:lower(), rawCode:sub(#firstLine + 2)
            end
        end
        return nil, rawCode
    end

    local function convertToRichText(rawText)
        local escaped = rawText:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;"):gsub('"', "&quot;"):gsub("'", "&apos;")
        local keywordColors = {
            ["important"] = "rgb(255, 120, 120)",
            ["note"] = "rgb(255, 200, 100)",
            ["warning"] = "rgb(255, 150, 80)",
            ["success"] = "rgb(120, 255, 150)",
            ["error"] = "rgb(255, 100, 100)",
            ["info"] = "rgb(120, 180, 255)",
            ["tip"] = "rgb(150, 255, 180)",
            ["example"] = "rgb(200, 150, 255)",
        }
        local result = escaped
        result = result:gsub("%*%*(.-)%*%*", "<font color=\"rgb(140, 200, 255)\"><b>%1</b></font>")
        result = result:gsub("%*(.-)%*", "<font color=\"rgb(255, 220, 140)\"><i>%1</i></font>")
        result = result:gsub("`(.-)`", "<font face=\"Code\" color=\"rgb(200, 255, 200)\">%1</font>")
        for keyword, color in pairs(keywordColors) do
            local pattern = "([%s%p]?)(" .. keyword .. ")([%s%p]?)"
            result = result:gsub(pattern, function(pre, word, post)
                return pre .. "<font color=\"" .. color .. "\"><b>" .. word .. "</b></font>" .. post
            end)
        end
        return result
    end

