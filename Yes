    local function extractRawName(userMessage)
        local q = userMessage:match("[\"']([^\"']+)[\"']")
        if q then return q end
        q = userMessage:match("[Pp]layer%s+([%w_]+)") or userMessage:match("[Uu]ser%s+([%w_]+)")
            or userMessage:match("[Kk]ullan[ıi]c[ıi]%s+([%w_]+)") or userMessage:match("[Oo]yuncu%s+([%w_]+)")
            or userMessage:match("[Kk]i[sş]i%s+([%w_]+)") or userMessage:match("[Hh]esab[ıi]%s+([%w_]+)")
            or userMessage:match("[Ii]smi%s+([%w_]+)") or userMessage:match("[Aa]d[ıi]%s+([%w_]+)")
        if q then return (q:gsub("[%.,!%?:]+$", "")) end
        for token in userMessage:gmatch("([%w_]+)") do
            local clean = token:gsub("[%.,!%?:]+$", "")
            if #clean >= 3 and not clean:match("^%d+$") and not RAW_NAME_STOP[clean:lower()] then
                return clean
            end
        end
        return nil
    end

    local function formatAccountCreated(info)
        if not info or not info.created then return nil end
        local y, mo, d = info.created:match("(%d+)%-(%d+)%-(%d+)")
        if y then return y .. "-" .. mo .. "-" .. d, y end
        return info.created, info.created:match("(%d+)")
    end

    local function accountAgeFromCreated(info)
        if not info or not info.created then return nil end
        local y, mo, d = info.created:match("(%d+)%-(%d+)%-(%d+)")
        if not y then return nil end
        local createdTime = os.time({year = tonumber(y), month = tonumber(mo), day = tonumber(d), hour = 12})
        local days = math.floor((os.time() - createdTime) / 86400)
        local years = days / 365.25
        return days, years
    end

