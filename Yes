                local textWidth = text_service:GetTextSize(sydecFull, 24, Enum.Font.GothamBold, Vector2.new(math.huge, math.huge)).X
                underline.Size = UDim2.new(0, 0, 0, 2)
                local tweenInfo = TweenInfo.new(0.6, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
                local tween = tween_service:Create(underline, tweenInfo, {Size = UDim2.new(0, textWidth, 0, 2)})
                tween:Play()
                hasShownWelcomeAnimation = true
            end)
        end
    }
end

if _G.AIConfig then
    _G.AIModule = createAIModule(_G.AIConfig)
    print("Sydec AI otomatik olarak başlatıldı.")
end

return createAIModule
