        local function EscapeHTML(s)
            return s:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;"):gsub('"', "&quot;")
        end

        local function RemoveComments(code)
            if not code or code == "" then
                return code
            end
            local lines = {}
            for line in code:gmatch("[^\r\n]*") do
                local pos = line:find("%-%-")
                if pos then
                    line = line:sub(1, pos - 1)
                end
                lines[#lines + 1] = line
            end
            return table.concat(lines, "\n")
        end

        local function HighlightLua(code)
            if not code or code == "" then
                return ""
            end
            local keywords = {"function","end","if","then","else","elseif","for","while","repeat","until","do","return","local","break","continue","goto","in","and","or","not","nil","true","false","require","pcall","xpcall","spawn","delay","wait","tick","time","typeof","type","rawequal","rawget","rawset","setmetatable","getmetatable","next","pairs","ipairs","select","unpack","pack","newproxy","self"}
            local builtins = {"print","warn","error","assert","Instance","Color3","Vector2","Vector3","CFrame","UDim2","UDim","NumberSequence","NumberRange","ColorSequence","Ray","Region3","Rect","BrickColor","Enum","TweenInfo","Axes","Faces","RaycastParams","DateTime","Random","string","table","math","coroutine","os","debug","utf8","bit32","workspace","game","script","shared","plugin","settings","stats","UserInputService","TweenService","RunService","Players","Lighting","Workspace","ReplicatedStorage","ReplicatedFirst"}
            local result = {}
            local lines = {}
            for line in code:gmatch("([^\n]*)\n?") do
                lines[#lines + 1] = line
            end
            if #lines == 0 then
                lines = {code}
            end
            for _, line in ipairs(lines) do
                local escaped = EscapeHTML(line)
                local hl = ""
                local pos = 1
                while pos <= #escaped do
                    local remaining = escaped:sub(pos)
                    local longStrMatch = remaining:match('^(%[%[.-%]%])')
                    local dqMatch = remaining:match('^"(.-)"')
                    local sqMatch = remaining:match("^'(.-)'")
                    local hexMatch = remaining:match('^(0[xX][%da-fA-F]+)')
                    local numMatch = remaining:match('^(%d+%.?%d*[eE]?[%+%-]?%d*)')
                    if not numMatch then
                        numMatch = remaining:match('^(%.%d+)')
                    end
                    local wordMatch = remaining:match('^([%a_][%w_]*)')
                    local best = nil
                    local bestLen = 0
                    local bestType = nil
                    if longStrMatch and #longStrMatch > bestLen then
                        best = longStrMatch
                        bestLen = #longStrMatch
                        bestType = "longstring"
                    end
                    if dqMatch and (#dqMatch + 2) > bestLen then
                        best = dqMatch
                        bestLen = #dqMatch + 2
                        bestType = "string"
                    end
                    if sqMatch and (#sqMatch + 2) > bestLen then
                        best = sqMatch
                        bestLen = #sqMatch + 2
                        bestType = "string"
                    end
                    if hexMatch and #hexMatch > bestLen then
                        best = hexMatch
                        bestLen = #hexMatch
                        bestType = "number"
                    end
                    if numMatch and #numMatch > bestLen then
                        best = numMatch
                        bestLen = #numMatch
                        bestType = "number"
                    end
                    if wordMatch and #wordMatch > bestLen then
                        best = wordMatch
                        bestLen = #wordMatch
                        bestType = "word"
                    end
                    if best then
                        if bestType == "longstring" then
                            hl = hl .. "<font color='#98c379'>" .. best .. "</font>"
                        elseif bestType == "string" then
                            local q = best:sub(1, 1)
                            local content = best:sub(2, #best - 1)
                            local esc = EscapeHTML(content)
                            local processed = ""
                            local ep = 1
                            while ep <= #esc do
                                local er = esc:sub(ep)
                                local es = er:match('^(\\[%a%d\\\'\"])')
                                if es then
                                    processed = processed .. "<font color='#e5c07b'>" .. es .. "</font>"
                                    ep = ep + #es
                                else
                                    processed = processed .. esc:sub(ep, ep)
                                    ep = ep + 1
                                end
                            end
                            hl = hl .. "<font color='#98c379'>" .. q .. processed .. q .. "</font>"
                        elseif bestType == "number" then
                            hl = hl .. "<font color='#d19a66'>" .. best .. "</font>"
                        elseif bestType == "word" then
                            local lower = best:lower()
                            local isKw = false
                            local isB = false
                            for _, k in ipairs(keywords) do
                                if k == lower then
                                    isKw = true
                                    break
                                end
                            end
                            if not isKw then
                                for _, b in ipairs(builtins) do
                                    if b == lower then
                                        isB = true
                                        break
                                    end
                                end
                            end
                            if isKw then
                                hl = hl .. "<font color='#c678dd'>" .. best .. "</font>"
                            elseif isB then
                                hl = hl .. "<font color='#61afef'>" .. best .. "</font>"
                            else
                                hl = hl .. best
                            end
                        end
                        pos = pos + bestLen
                    else
                        hl = hl .. escaped:sub(pos, pos)
                        pos = pos + 1
                    end
                end
                result[#result + 1] = hl
            end
            return table.concat(result, "\n")
        end

