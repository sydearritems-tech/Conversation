    local function findStatInLeaderstats(ls, wantKey)
        if not ls then return nil end
        local children = ls:GetChildren()
        if wantKey then
            local aliases = STAT_ALIASES[wantKey] or {wantKey}
            table.insert(aliases, 1, wantKey)
            for _, alias in ipairs(aliases) do
                for _, s in ipairs(children) do
                    if s.Name:lower():find(alias:lower(), 1, true) then
                        return s
                    end
                end
            end
            return nil
        end
        local best
        for _, s in ipairs(children) do
            local ok, num = pcall(function() return tonumber(s.Value) end)
            if ok and num then
                if not best then best = s end
            end
        end
        return best or children[1]
    end

    local function detectStatKey(lower)
