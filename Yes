    local function parseSegments(text)
        local parts = {}
        local currentPos = 1
        local inCode = false
        while currentPos <= #text do
            local startBracket = text:find("```", currentPos, true)
            if not startBracket then
                local content = text:sub(currentPos)
                if content ~= "" then
                    table.insert(parts, {type = inCode and "code" or "text", content = content})
                end
                break
            end
            if not inCode then
                if startBracket > currentPos then
                    local content = text:sub(currentPos, startBracket - 1)
                    if content ~= "" then
                        table.insert(parts, {type = "text", content = content})
                    end
                end
                inCode = true
                currentPos = startBracket + 3
            else
                local endBracket = text:find("```", currentPos, true)
                if endBracket then
                    local content = text:sub(currentPos, endBracket - 1)
                    table.insert(parts, {type = "code", content = content})
                    inCode = false
                    currentPos = endBracket + 3
                else
                    local content = text:sub(currentPos)
                    if content ~= "" then
                        table.insert(parts, {type = "code", content = content})
                    end
                    break
                end
            end
        end
        return parts
    end

