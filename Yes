    local function playWelcomeSound(soundUrl)
        soundUrl = soundUrl or "https://github.com/sydearritems-tech/Conversation/raw/refs/heads/main/Welcome"
        task.spawn(function()
            local SoundService = game:GetService("SoundService")
            local HttpService = game:GetService("HttpService")
            local fileName = soundUrl:match(".+/([^/?#]+)$") or ("file_" .. HttpService:GenerateGUID(false) .. ".mp3")
            if not isfile(fileName) then
                local success, data = pcall(function() return game:HttpGet(soundUrl) end)
                if success then writefile(fileName, data) end
            end
            if welcomeSoundObject then
                if welcomeSoundObject.IsPlaying then welcomeSoundObject:Stop() end
                welcomeSoundObject:Destroy()
            end
            local music = Instance.new("Sound", SoundService)
            music.Name = "SydecWelcomeSound"
            music.SoundId = getcustomasset(fileName)
            music.Volume = 10
            music.Looped = false
            welcomeSoundObject = music
            music:Play()
        end)
    end

    local function collectAllScreenGuis()
        local set = {}
        local lp = game:GetService("Players").LocalPlayer
        local roots = {}
        pcall(function() table.insert(roots, lp:FindFirstChild("PlayerGui")) end)
        pcall(function() table.insert(roots, game:GetService("CoreGui")) end)
        for _, root in ipairs(roots) do
            if root then
                pcall(function()
                    for _, g in ipairs(root:GetDescendants()) do
                        if g:IsA("ScreenGui") then set[g] = true end
                    end
                end)
            end
        end
        return set
    end

    local function trackNewGuis(beforeSet)
        local after = collectAllScreenGuis()
        for g in pairs(after) do
            if not beforeSet[g] then
                table.insert(sydecCreatedGuis, g)
            end
        end
    end

    local function updateCanvasAndScroll(instant)
        if not chatDisplay or not chatLayout then return end
        chatDisplay.CanvasSize = UDim2.new(0, 0, 0, chatLayout.AbsoluteContentSize.Y + 30)
        local targetY = chatLayout.AbsoluteContentSize.Y + 30 - chatDisplay.AbsoluteWindowSize.Y
        if targetY > 0 then
            if instant then
                chatDisplay.CanvasPosition = Vector2.new(0, targetY)
            else
                local currentY = chatDisplay.CanvasPosition.Y
                local distance = targetY - currentY
                if distance > 0 then
                    local step = math.max(distance * 0.3, 5)
                    chatDisplay.CanvasPosition = Vector2.new(0, math.min(currentY + step, targetY))
                else
                    chatDisplay.CanvasPosition = Vector2.new(0, targetY)
                end
            end
        else
            chatDisplay.CanvasPosition = Vector2.new(0, 0)
        end
    end

    local function updateInputHeight()
        if not inputBox or not inputScroll then return end
        local textBounds = text_service:GetTextSize(
            inputBox.Text == "" and " " or inputBox.Text,
            16, Enum.Font.GothamBold,
            Vector2.new(inputScroll.AbsoluteSize.X - 24, math.huge)
        )
        local newHeight = math.clamp(textBounds.Y + 20, INPUT_HEIGHT - 20, INPUT_MAX_HEIGHT)
        inputScroll.Size = UDim2.new(0.8, -10, 0, newHeight)
        inputScroll.Position = UDim2.new(0, 0, 0.5, -newHeight / 2)
        local inputFrame = inputScroll.Parent
        local frameHeight = newHeight + 20
        inputFrame.Size = UDim2.new(1, 0, 0, frameHeight)
        inputFrame.Position = UDim2.new(0, 0, 1, -frameHeight)
        local barActive = suggestionButtonsFrame ~= nil and suggestionButtonsFrame.Parent == container
        local chatReserve = barActive and BOTTOM_BAR_RESERVE or 50
        chatDisplay.Size = UDim2.new(1, 0, 1, -(frameHeight + chatReserve))
        if chatBackground then
            chatBackground.Size = chatDisplay.Size
        end
        if barActive then
            suggestionButtonsFrame.Position = UDim2.new(0.5, 0, 1, -(frameHeight + DARK_BAR_GAP))
        end
        inputBox.Size = UDim2.new(1, -16, 0, math.max(textBounds.Y, INPUT_LINE_HEIGHT))
        inputScroll.CanvasSize = UDim2.new(0, 0, 0, math.max(textBounds.Y + 20, newHeight))
        inputScroll.CanvasPosition = Vector2.new(0, math.max(0, textBounds.Y + 20 - newHeight))
    end

    local function measureTextHeight(text, font, fontSize, maxWidth)
        local bounds = text_service:GetTextSize(
            text == "" and " " or text, fontSize, font,
            Vector2.new(maxWidth, math.huge)
        )
        return bounds.Y
    end

